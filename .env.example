# 认证方式 (二选一):
#
# 方式1 (推荐): OAuth 登录，类似 claude login / codex login
#   运行: persona-agent login anthropic
#   运行: persona-agent login openai
#   Token 自动缓存到 ~/.persona-agent/tokens/
#
# 方式2: 传统 API Key (作为 fallback)
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx

# Optional: TTS/STT Providers (future)
# TTS_API_KEY=
# STT_API_KEY=

# Embeddings: 火山方舟豆包 (fewshot pool + 语义检索)
# ARK_API_KEY=<你的方舟 API key>
# EMBEDDING_MODEL=ep-xxxxxxxxxxxxx    # 你在方舟控制台创建的接入点 ID; 留空则用 config/default.yaml 里的默认

# Feishu Bot (optional)
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx

# Memory Settings
MEMORY_DATA_DIR=./data/memory

# Logging
LOG_LEVEL=INFO
